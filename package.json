{
  "name": "runn-scenario-runner",
  "displayName": "runn-scenario-runner",
  "description": "VS Code extension for running runn scenario tests",
  "version": "0.0.5",
  "publisher": "cozy-harbor",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cozy-harbor/runn-scenario-runner.git"
  },
  "bugs": {
    "url": "https://github.com/cozy-harbor/runn-scenario-runner/issues"
  },
  "homepage": "https://github.com/cozy-harbor/runn-scenario-runner#readme",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "workspaceContains:**/*.run.yml",
    "workspaceContains:**/runbook.yml",
    "onCommand:runn-scenario-runner.activate"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "runn-scenario-runner.activate",
        "title": "runn: Activate Test Explorer"
      },
      {
        "command": "runn-scenario-runner.runCurrentFile",
        "title": "runn: Run Current Scenario",
        "icon": "$(play)"
      }
    ],
    "keybindings": [
      {
        "command": "runn-scenario-runner.runCurrentFile",
        "key": "cmd+alt+r",
        "mac": "cmd+alt+r",
        "win": "ctrl+alt+r",
        "when": "editorLangId == yaml"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "runn-scenario-runner.runCurrentFile",
          "when": "resourceLangId == yaml",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "runn-scenario-runner.runCurrentFile",
          "when": "resourceLangId == yaml",
          "group": "testing"
        }
      ]
    },
    "configuration": {
      "title": "runn Scenario Runner",
      "properties": {
        "runn.path": {
          "type": "string",
          "default": "runn",
          "scope": "resource",
          "description": "Path to the runn CLI binary (e.g., /usr/local/bin/runn or just runn if it's in your PATH)."
        },
        "runn.extraArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Extra arguments to pass to the runn run command."
        },
        "runn.testDirectory": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "description": "Directory containing the scenario files (e.g., 'sample_tests'). If specified, all .yml and .yaml files in this directory will be detected as tests."
        },
        "runn.testFilePattern": {
          "type": "string",
          "default": "**/{*.run.yml,runbook.yml}",
          "scope": "resource",
          "description": "Glob pattern to detect test files when runn.testDirectory is not specified."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "bun run package",
    "compile": "bun run check-types && bun run lint && bun esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "bun esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && bun esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
