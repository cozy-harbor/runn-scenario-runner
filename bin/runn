#!/usr/bin/env node

const fs = require('fs');
const path = require('path');

// 引数から実行コマンドとターゲットファイルを取得
const args = process.argv.slice(2);
const command = args[0];
const targetFile = args[1];

if (command !== 'run') {
  console.log('Mock runn: Only "run" command is supported in this mock.');
  process.exit(1);
}

if (!targetFile) {
  console.log('Error: No target scenario file specified.');
  process.exit(1);
}

const basename = path.basename(targetFile);

console.log(`\x1b[36m=== mock-runn: Running scenario: ${basename} ===\x1b[0m`);
console.log(`\x1b[90mSource: ${targetFile}\x1b[0m\n`);

// ステップのシミュレーション
setTimeout(() => {
  console.log('\x1b[34m[step 1]\x1b[0m Sending GET request to https://httpbin.org/get ...');
}, 300);

setTimeout(() => {
  console.log('  → Status: \x1b[32m200 OK\x1b[0m');
  console.log('  → Response Body: { "status": "ok", "message": "hello from mock-runn" }');
}, 700);

setTimeout(() => {
  console.log('\x1b[34m[step 2]\x1b[0m Verifying response status code...');
  
  // ファイル名に 'fail' が含まれる場合は失敗させる
  const shouldFail = basename.toLowerCase().includes('fail');

  if (shouldFail) {
    console.error('\n\x1b[31mError: Assertion failed!\x1b[0m');
    console.error('  Expected: \x1b[32mcurrent.res.status == 200\x1b[0m');
    console.error('  Actual:   \x1b[31mcurrent.res.status == 500\x1b[0m');
    console.log(`\n\x1b[31m1 scenario, 1 step, 1 failed\x1b[0m`);
    process.exit(1);
  } else {
    console.log('  → Assertion passed: \x1b[32mcurrent.res.status == 200\x1b[0m');
    console.log(`\n\x1b[32m1 scenario, 2 steps, 0 failed (all passed)\x1b[0m`);
    process.exit(0);
  }
}, 1200);
