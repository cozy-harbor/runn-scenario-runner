// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "watch",
			"dependsOn": [
				"bun: watch:tsc",
				"bun: watch:esbuild"
			],
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			}
		},
		{
			"type": "shell",
			"command": "bun run watch:esbuild",
			"group": "build",
			"problemMatcher": {
				"owner": "esbuild",
				"fileLocation": "relative",
				"pattern": {
					"regexp": "^\\s*(✘|✖)\\s*\\[ERROR\\]\\s*(.*)$",
					"message": 2
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started",
					"endsPattern": "^\\[watch\\] build finished"
				}
			},
			"isBackground": true,
			"label": "bun: watch:esbuild",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		},
		{
			"type": "shell",
			"command": "bun run watch:tsc",
			"group": "build",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"label": "bun: watch:tsc",
			"presentation": {
				"group": "watch",
				"reveal": "never"
			}
		}
	]
}
